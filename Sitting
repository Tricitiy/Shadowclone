-- [[ SETTINGS ]] --
local tween_speed = 25; 
local max_distance = 300;
local KEYWORDS = {"coin", "gold", "token", "gem"};
local MAX_COINS = 40; -- Counter limit before death

local map;
local coins;
local last_coin;
local coinCount = 0; -- Counter

local players = game:GetService("Players");
local localplayer = players.LocalPlayer;
local camera = workspace.CurrentCamera;

function draw(type)
    local new_draw = Drawing.new(type);
    new_draw.Transparency = 1;
    new_draw.Visible = true;
    return new_draw;
end;

function is_valid(obj)
    return obj and obj.Parent ~= nil;
end;

local function matches_keywords(name)
    local ln = string.lower(name)
    for _, kw in ipairs(KEYWORDS) do
        if string.find(ln, kw) then return true end
    end
    return false
end

------------------------------------------------------------
-- Reset counter on death
------------------------------------------------------------
local function setupDeathReset(character)
    local humanoid = character:WaitForChild("Humanoid")
    humanoid.Died:Connect(function()
        coinCount = 0
        print("[Coin Farm] Died — counter reset to 0")
    end)
end

if localplayer.Character then
    setupDeathReset(localplayer.Character)
end
localplayer.CharacterAdded:Connect(function(char)
    coinCount = 0 -- reset on respawn too
    setupDeathReset(char)
end)

------------------------------------------------------------
-- Coin tracking
------------------------------------------------------------
local lastCoinPos = nil

local function checkCoinCollected(root, closest_coin)
    if not closest_coin or not is_valid(closest_coin) then return end
    local dist = (root.Position - closest_coin.Position).Magnitude
    -- If we got within 2 studs of the coin, count it
    if dist < 2 then
        if lastCoinPos ~= closest_coin then
            lastCoinPos = closest_coin
            coinCount += 1
            print("[Coin Farm] Coins collected: " .. coinCount .. "/" .. MAX_COINS)

            -- Kill character at 40
            if coinCount >= MAX_COINS then
                print("[Coin Farm] Reached " .. MAX_COINS .. " coins — dying")
                local character = localplayer.Character
                if character then
                    local humanoid = character:FindFirstChildOfClass("Humanoid")
                    if humanoid then
                        humanoid.Health = 0
                    end
                end
            end
        end
    end
end

function get_closest_coin()
    local closest_coin = nil;
    local closest_distance = max_distance;

    local character = localplayer.Character;
    if not character or not character:FindFirstChild("HumanoidRootPart") then return nil, closest_distance end;

    local rootPos = character.HumanoidRootPart.Position;
    
    if is_valid(map) then
        for _, obj in next, map:GetDescendants() do
            if obj:IsA("BasePart") and matches_keywords(obj.Name) and obj:FindFirstChild("TouchInterest") then
                local dist = (obj.Position - rootPos).Magnitude
                if dist < closest_distance then
                    closest_distance = dist;
                    closest_coin = obj;
                end;
            end;
        end;
    end;

    return closest_coin, closest_distance;
end;

local can_tween = true;

function tween_position(object, target, duration)
    local start_time = os.clock();
    local start_pos = object.Position;
    local end_time = start_time + duration;
    can_tween = false;

    while os.clock() < end_time do
        if (not is_valid(object)) or (not is_valid(target)) or (not is_valid(map)) then
            break;
        end;

        local alpha = (os.clock() - start_time) / duration;
        if alpha > 1 then alpha = 1 end;

        object.Position = start_pos:Lerp(target.Position, alpha)
        object.Velocity = Vector3.new(0, 0, 0);
        task.wait() 
    end;

    can_tween = true;
    if is_valid(object) and is_valid(target) then
        object.Position = target.Position;
    end
end;

function set_noclip()
    local character = localplayer.Character;
    if character then
        for i, v in next, character:GetChildren() do
            if v:IsA("BasePart") then
                v.CanCollide = false;
            end;
        end;
    end;
end;

------------------------------------------------------------
-- Status text (now shows coin counter too)
------------------------------------------------------------
local status = draw("Text");
status.Center = true;
status.Size = 18;
status.Color = Color3.fromRGB(255, 255, 255);

local counterText = draw("Text");
counterText.Center = true;
counterText.Size = 18;
counterText.Color = Color3.fromRGB(255, 215, 0); -- gold color

function update_auto_farm()
    local screen_size = camera.ViewportSize;
    status.Position = Vector2.new(screen_size.X / 2, screen_size.Y * 0.2);
    counterText.Position = Vector2.new(screen_size.X / 2, screen_size.Y * 0.2 + 24);
    counterText.Text = "Coins: " .. coinCount .. " / " .. MAX_COINS;

    for _, v in next, workspace:GetChildren() do
        if v:FindFirstChild("Spawns") and v.Name ~= "Lobby" then
            map = v;
        end;
    end;

    set_noclip();

    pcall(function() 
        coins = localplayer.PlayerGui.MainGUI.Game.CoinBags.Container.Candy.CurrencyFrame.Icon.Coins
    end);

    local character = localplayer.Character;
    local root = character and character:FindFirstChild("HumanoidRootPart")
    
    if root then
        if is_valid(map) and (not coins or coins.Text ~= "50") then
            local closest_coin, coin_distance = get_closest_coin();

            if is_valid(closest_coin) then
                status.Text = "Auto Farming: " .. closest_coin.Name .. " (" .. math.floor(coin_distance) .. " studs)";

                -- Check if we collected a coin
                checkCoinCollected(root, closest_coin)

                if can_tween then
                    task.spawn(function() 
                        tween_position(root, closest_coin, coin_distance / tween_speed); 
                    end);
                end;
            else
                status.Text = "Status: No items within " .. max_distance .. " studs";
            end;
        else
            status.Text = "Status: IDLE / Bag Full / No Map";
            root.Velocity = Vector3.new(0, 0, 0);
        end;
    end;
end;

while true do
    update_auto_farm();
    task.wait(0.1); 
end;
