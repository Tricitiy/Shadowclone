local Players      = game:GetService("Players")
local RunService   = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local LocalPlayer  = Players.LocalPlayer

getgenv().CoinFarmEnabled = true
getgenv().TweenSpeed      = 23
getgenv().MaxDistance     = 300

local KEYWORDS = {"coin", "gold", "token", "gem"}
local ItemCache = {}

-- 1. Optimized Name Check
local function isTarget(name)
    local ln = name:lower()
    for _, kw in ipairs(KEYWORDS) do
        if ln:find(kw) then return true end
    end
    return false
end

-- 2. Fast Cache Refresh (Only runs when necessary)
local function refreshCache()
    local newCache = {}
    -- This is still a heavy check, so we only do it once or when the farm starts
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and isTarget(v.Name) then
            table.insert(newCache, v)
        end
    end
    ItemCache = newCache
end

-- 3. Dynamic Cache Update (Watches for new spawns)
workspace.DescendantAdded:Connect(function(v)
    if v:IsA("BasePart") and isTarget(v.Name) then
        table.insert(ItemCache, v)
    end
end)

-- 4. The Distance Logic (The optimized part)
local function getClosestTarget()
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    
    local rootPos = root.Position
    local closest = nil
    local dist = getgenv().MaxDistance

    -- Loop through our pre-filtered table (very fast)
    for i = #ItemCache, 1, -1 do
        local item = ItemCache[i]
        
        -- If item was deleted/collected, remove from cache and skip
        if not item or not item.Parent then
            table.remove(ItemCache, i)
        else
            local d = (item.Position - rootPos).Magnitude
            if d < dist then
                dist = d
                closest = item
            end
        end
    end
    return closest
end

-- 5. Noclip
RunService.Stepped:Connect(function()
    if getgenv().CoinFarmEnabled and LocalPlayer.Character then
        for _, part in ipairs(LocalPlayer.Character:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end
end)

-- 6. Tween
local function tweenTo(targetCFrame)
    local root = LocalPlayer.Character.HumanoidRootPart
    local d = (root.Position - targetCFrame.Position).Magnitude
    local t = TweenService:Create(root, TweenInfo.new(d/getgenv().TweenSpeed, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
    t:Play()
    t.Completed:Wait()
end

-- Initial scan
refreshCache()

-- Main Execution
task.spawn(function()
    while true do
        task.wait(0.1)
        if getgenv().CoinFarmEnabled then
            local target = getClosestTarget()
            if target then
                pcall(function() tweenTo(target.CFrame) end)
            end
        end
    end
end)
