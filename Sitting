-- Get Role Function
local function getRole(plr)
   local char = plr.Character
   local backpack = plr.Backpack
   if char:FindFirstChild("Knife") or backpack:FindFirstChild("Knife") then return "Murderer" end
   if char:FindFirstChild("Gun") or backpack:FindFirstChild("Gun") then return "Sheriff" end
   return "Innocent"
end

-- ESP System
local function createESP(plr)
   if plr == LocalPlayer then return end
   local box = Drawing.new("Square")
   box.Thickness = 2
   box.Filled = false
   box.Transparency = 1
   box.Visible = false
   local name = Drawing.new("Text")
   name.Size = 14
   name.Center = true
   name.Outline = true
   name.Font = 2
   name.Visible = false
   local distText = Drawing.new("Text")
   distText.Size = 12
   distText.Center = true
   distText.Outline = true
   distText.Font = 2
   distText.Visible = false
   ESPs[plr] = {box = box, name = name, dist = distText}
end

local updateESP = function()
   if not getgenv().ESPEnabled then return end
   for plr, esp in pairs(ESPs) do
      if plr.Parent and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character:FindFirstChild("Head") then
         local root = plr.Character.HumanoidRootPart
         local head = plr.Character.Head
         local hum = plr.Character:FindFirstChildOfClass("Humanoid")
         local rootPos, onScreen = Camera:WorldToViewportPoint(root.Position)
         local headPos = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
         if onScreen then
            local legPos = rootPos.Y + (Camera:WorldToViewportPoint(root.Position - Vector3.new(0,5,0)).Y - rootPos.Y)
            local size = math.abs(legPos - rootPos.Y)
            local width = size / 2
            esp.box.Size = Vector2.new(width * 2, size)
            esp.box.Position = Vector2.new(rootPos.X - width, rootPos.Y - size / 2)
            esp.box.Visible = true
            local role = getRole(plr)
            local color = role == "Murderer" and Color3.fromRGB(255,0,0) or role == "Sheriff" and Color3.fromRGB(0,100,255) or Color3.fromRGB(0,255,0)
            esp.box.Color = color
            local dist = math.floor((LocalPlayer.Character.HumanoidRootPart.Position - root.Position).Magnitude)
            esp.name.Text = plr.Name .. " [" .. role .. "]"
            esp.name.Position = Vector2.new(rootPos.X, rootPos.Y - size / 2 - 20)
            esp.name.Color = color
            esp.name.Visible = true
            esp.dist.Text = dist .. "m | " .. math.floor(hum.Health)
            esp.dist.Position = Vector2.new(rootPos.X, rootPos.Y + size / 2 + 5)
            esp.dist.Color = Color3.fromRGB(255,255,255)
            esp.dist.Visible = true
         else
            esp.box.Visible = false
            esp.name.Visible = false
            esp.dist.Visible = false
         end
      else
         esp.box.Visible = false
         esp.name.Visible = false
         esp.dist.Visible = false
      end
   end
end
Connections.ESP = RunService.RenderStepped:Connect(updateESP)

-- Player Added/Removing
Players.PlayerAdded:Connect(createESP)
for _, plr in pairs(Players:GetPlayers()) do createESP(plr) end
Players.PlayerRemoving:Connect(function(plr)
   if ESPs[plr] then
      ESPs[plr].box:Remove()
      ESPs[plr].name:Remove()
      ESPs[plr].dist:Remove()
      ESPs[plr] = nil
   end
end)

-- Aimbot
local updateAimbot = function()
   if not getgenv().AimbotEnabled then return end
   local myRole = getRole(LocalPlayer)
   local closest, dist = nil, math.huge
   local myPos = LocalPlayer.Character.HumanoidRootPart.Position
   for _, plr in pairs(Players:GetPlayers()) do
      if plr \~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("Head") then
         local role = getRole(plr)
         if (myRole \~= "Murderer" and role == "Murderer") or (myRole == "Murderer" and role \~= "Murderer") then
            local targetPos = plr.Character.Head.Position
            local d = (myPos - targetPos).Magnitude
            if d < dist then
               closest = plr
               dist = d
            end
         end
      end
   end
   if closest and closest.Character and closest.Character:FindFirstChild("Head") then
      Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, closest.Character.Head.Position)
   end
end
Connections.Aimbot = RunService.RenderStepped:Connect(updateAimbot)

