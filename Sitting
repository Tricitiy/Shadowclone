local Players      = game:GetService("Players")
local RunService   = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local LocalPlayer  = Players.LocalPlayer

getgenv().CoinFarmEnabled = true
getgenv().TweenSpeed      = 25
getgenv().MaxDistance     = 300

local KEYWORDS  = {"coin", "gold", "token", "gem"}
local ItemCache = {}
local isTweening = false

local function isTarget(name)
    local ln = name:lower()
    for _, kw in ipairs(KEYWORDS) do
        if ln:find(kw) then return true end
    end
    return false
end

-- Only called once on start
local function refreshCache()
    ItemCache = {}
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and isTarget(v.Name) then
            table.insert(ItemCache, v)
        end
    end
end

-- Live additions
workspace.DescendantAdded:Connect(function(v)
    if v:IsA("BasePart") and isTarget(v.Name) then
        table.insert(ItemCache, v)
    end
end)

-- Live removals — this is what kills the delay
workspace.DescendantRemoving:Connect(function(v)
    if v:IsA("BasePart") and isTarget(v.Name) then
        for i, item in ipairs(ItemCache) do
            if item == v then
                table.remove(ItemCache, i)
                break
            end
        end
    end
end)

local function getClosestTarget()
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end

    local rootPos = root.Position
    local closest, closestDist = nil, getgenv().MaxDistance

    for i = #ItemCache, 1, -1 do
        local item = ItemCache[i]
        if not item or not item.Parent then
            table.remove(ItemCache, i)
        else
            local d = (item.Position - rootPos).Magnitude
            if d < closestDist then
                closestDist = d
                closest = item
            end
        end
    end
    return closest
end

-- Noclip
LocalPlayer.CharacterAdded:Connect(function(char)
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then part.CanCollide = false end
    end
    char.DescendantAdded:Connect(function(part)
        if part:IsA("BasePart") then part.CanCollide = false end
    end)
end)

local currentTween = nil

local function tweenTo(targetCFrame)
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    if currentTween then
        currentTween:Cancel()
        currentTween = nil
    end

    local d = (root.Position - targetCFrame.Position).Magnitude
    if d < 1 then
        isTweening = false
        return
    end

    isTweening = true
    currentTween = TweenService:Create(
        root,
        TweenInfo.new(d / getgenv().TweenSpeed, Enum.EasingStyle.Linear),
        {CFrame = targetCFrame}
    )

    currentTween.Completed:Connect(function()
        isTweening = false
    end)

    currentTween:Play()
end

-- Initial scan
refreshCache()

-- Main loop
task.spawn(function()
    while true do
        task.wait(0.05)
        if getgenv().CoinFarmEnabled and not isTweening then
            local target = getClosestTarget()
            if target and target.Parent then
                pcall(tweenTo, target.CFrame)
            end
        end
    end
end)

-- Watchdog: coin disappears mid-tween, cancel immediately
RunService.Heartbeat:Connect(function()
    if not getgenv().CoinFarmEnabled or not isTweening then return end
    if not getClosestTarget() then
        if currentTween then
            currentTween:Cancel()
            currentTween = nil
        end
        isTweening = false
    end
end)
