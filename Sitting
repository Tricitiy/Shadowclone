local Players      = game:GetService("Players")
local RunService   = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local LocalPlayer  = Players.LocalPlayer

getgenv().CoinFarmEnabled = true
getgenv().TweenSpeed      = 23
getgenv().MaxDistance     = 300 -- THE LIMIT

local KEYWORDS = {"coin", "gold", "token", "gem"}
local ValidTargets = {}

local function checkName(name)
    local ln = string.lower(name)
    for _, kw in ipairs(KEYWORDS) do
        if string.find(ln, kw) then return true end
    end
    return false
end

local function setupCache()
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and checkName(v.Name) then
            table.insert(ValidTargets, v)
        end
    end
end

workspace.DescendantAdded:Connect(function(v)
    if v:IsA("BasePart") and checkName(v.Name) then
        table.insert(ValidTargets, v)
    end
end)

local function getClosestTarget()
    local closestPart = nil
    local shortestDistance = getgenv().MaxDistance -- Start at 300 so nothing further is considered
    
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local rootPos = char.HumanoidRootPart.Position

    for i = #ValidTargets, 1, -1 do
        local v = ValidTargets[i]
        if v and v.Parent then
            local dist = (v.Position - rootPos).Magnitude
            -- Only pick it if it's the closest AND under the 300 stud limit
            if dist < shortestDistance then
                shortestDistance = dist
                closestPart = v
            end
        else
            table.remove(ValidTargets, i)
        end
    end
    return closestPart
end

RunService.Stepped:Connect(function()
    if getgenv().CoinFarmEnabled and LocalPlayer.Character then
        for _, part in ipairs(LocalPlayer.Character:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end
end)

local function tweenTo(targetCFrame)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local root = char.HumanoidRootPart
    local duration = (root.Position - targetCFrame.Position).Magnitude / getgenv().TweenSpeed

    local tween = TweenService:Create(root, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
    tween:Play()
    tween.Completed:Wait()
end

setupCache()

task.spawn(function()
    while true do
        task.wait(0.1)
        if getgenv().CoinFarmEnabled then
            local target = getClosestTarget()
            if target then
                pcall(function() tweenTo(target.CFrame) end)
            end
        end
    end
end)
