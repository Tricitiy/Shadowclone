local Players      = game:GetService("Players")
local RunService   = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local LocalPlayer  = Players.LocalPlayer

getgenv().CoinFarmEnabled = true
getgenv().TweenSpeed      = 23

local KEYWORDS = {"coin", "gold", "token", "gem"}

-- Check if name matches keywords
local function isTarget(part)
    if not (part:IsA("BasePart") and part.Parent) then return false end
    local lowerName = string.lower(part.Name)
    for _, word in ipairs(KEYWORDS) do
        if string.find(lowerName, word) then return true end
    end
    return false
end

